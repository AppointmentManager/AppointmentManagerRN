# API Configuration
# Copy this file to .env and update with your actual values

# API Base URL - Your backend server address
# For iOS Simulator: http://localhost:8080/api
# For Android Emulator: http://10.0.2.2:8080/api (Android emulator maps 10.0.2.2 to host's localhost)
# For Physical Device: http://<your-machine-ip>:8080/api
API_BASE_URL="http://localhost:8080/api"

# API request timeout in milliseconds (30 seconds)
API_TIMEOUT="30000"

# Environment: development | staging | production
NODE_ENV="development"
